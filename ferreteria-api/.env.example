# ---------------------------------------------------------------------------
# Ferreteria API (NestJS) — variables de entorno
# Copia este archivo a .env y completa los valores.
# ---------------------------------------------------------------------------

# PostgreSQL. Prisma lee esta variable.
DATABASE_URL="postgresql://ferreteria:ferreteria@localhost:5432/ferreteria_db?schema=public"

# JWT — equivalentes a SIMPLE_JWT de Django (access 15m, refresh 24h).
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="24h"

# Cifrado de campos sensibles (document_number). DEBE ser la MISMA clave Fernet
# usada por el proyecto Django (.env -> FIELD_ENCRYPTION_KEY) para poder leer
# los datos migrados. Es una clave Fernet base64 urlsafe de 32 bytes.
FIELD_ENCRYPTION_KEY=""

# Bloqueo de cuenta (paridad con accounts/signals.py de Django).
MAX_FAILED_LOGIN_ATTEMPTS="5"
ACCOUNT_LOCKOUT_MINUTES="3"

# CORS — origenes permitidos separados por coma. Vacio = ninguno.
CORS_ALLOWED_ORIGINS="http://localhost:8000,https://*.ngrok-free.app"

# Servidor
PORT="3000"
TZ="America/Bogota"
